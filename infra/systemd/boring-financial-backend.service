[Unit]
Description=Boring Financial FastAPI Backend
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/Boring-Financial/backend
EnvironmentFile=/opt/Boring-Financial/backend/.env
ExecStart=/opt/Boring-Financial/backend/.venv/bin/uvicorn backend.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
