APP_NAME=Boring Financial API
APP_ENV=dev
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/boring_financial
REDIS_URL=redis://localhost:6379/0
CLASSIFICATION_PROVIDER=composite
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MODEL_TIMEOUT_SECONDS=30
MODEL_CONNECT_TIMEOUT_SECONDS=5
MODEL_MAX_RETRIES=2
MODEL_MAX_OUTPUT_TOKENS=80
IMPORT_CLASSIFICATION_WORKERS=2
IMPORT_PROGRESS_COMMIT_INTERVAL=10
LOCAL_MODEL_API_BASE=http://model-service:8001/v1
LOCAL_MODEL_API_KEY=EMPTY
LOCAL_MODEL_NAME=Qwen2.5-7B-Instruct
LOW_CONFIDENCE_THRESHOLD=0.75
STORAGE_DIR=./storage
TASK_ALWAYS_EAGER=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
